# Your OpenAI API key
OPENAI_API_KEY=sk-xxxxxxx

# Optional OpenAI Base URL
OPENAI_API_BASE=https://api.siliconflow.cn/v1

# Optional model name
DOCS_MCP_EMBEDDING_MODEL=BAAI/bge-m3

# Embedding Rate Limiting Configuration

DOCS_MCP_EMBEDDING_RATE_LIMIT=true

# Delay between embedding requests in milliseconds (default: 150)
DOCS_MCP_EMBEDDING_DELAY_MS=150

# Maximum requests per minute (default: 1800, recommended: 90% of your API limit)
DOCS_MCP_EMBEDDING_MAX_RPM=1800

# Maximum tokens per minute (default: 800000, recommended: 80% of your API limit)
DOCS_MCP_EMBEDDING_MAX_TPM=800000

# Maximum retries for 429 errors (default: 3)
DOCS_MCP_EMBEDDING_MAX_RETRIES=3

# Base retry delay in milliseconds, doubles with each retry (default: 1000)
DOCS_MCP_EMBEDDING_RETRY_BASE_DELAY_MS=1000
